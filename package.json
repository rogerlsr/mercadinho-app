{
  "name": "mercadinho",
  "version": "1.0.0",
  "description": "Sistema de Caixa - Mercadinho",
  "main": "main.js",
  "author": "Roger",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.mercadinho.caixa",
    "productName": "Mercadinho",
    "copyright": "Roger",
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mercadinho"
    },
    "files": [
      "main.js",
      "src/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
